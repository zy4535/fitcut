# Copy this file to ".env" and fill in your Supabase project values.
# Find them in Supabase: Project Settings -> API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional but recommended for better food search (free key):
# https://fdc.nal.usda.gov/api-key-signup
VITE_USDA_API_KEY=DEMO_KEY

# Optional: enables the photo calorie estimator (server-side only, NOT VITE_).
# Add this in Vercel project settings, not in the frontend. Get a key at console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# Optional photo estimator (server-side only, NOT VITE_). Use ONE:
# GEMINI_API_KEY=...      # free, no credit card: aistudio.google.com
# ANTHROPIC_API_KEY=...   # paid: console.anthropic.com
